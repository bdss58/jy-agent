{
  "mcpServers": {
    "chrome": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--ignoreDefaultChromeArg=--enable-automation",
        "--chromeArg=--disable-blink-features=AutomationControlled"
      ],
      "env": {},
      "prefix": true,
      "connect": "lazy",
      "startup_wait": 5,
      "init_timeout": 30
    }
  }
}
