# ============================================================
# AI Agent Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then load into your shell:
#   export $(cat .env | xargs)

# ────────────────────────────────────────────────────────────
# Runtime Selection
# ────────────────────────────────────────────────────────────

# Default provider for interactive chat, subagents, memory summaries, and skill routing.
# Supported providers: anthropic, openai
AGENT_PROVIDER=anthropic

# Default model for the active provider.
AGENT_MODEL=claude-sonnet-4-6

# Default max output tokens per response.
AGENT_MAX_TOKENS=16384

# Hard cap for automatic token-budget retries.
AGENT_MAX_TOKENS_CAP=128000

# ────────────────────────────────────────────────────────────
# Anthropic API — Authentication
# ────────────────────────────────────────────────────────────

# Your Anthropic API key (required — unless ANTHROPIC_AUTH_TOKEN is set)
ANTHROPIC_API_KEY=your-key-here

# Alternative auth token — overrides ANTHROPIC_API_KEY when set.
# Useful for API gateways or proxy services with their own credentials.
ANTHROPIC_AUTH_TOKEN=your-auth-token-here

# ────────────────────────────────────────────────────────────
# Anthropic API — Endpoint & Model
# ────────────────────────────────────────────────────────────

# API base URL — override for proxies, gateways, or self-hosted endpoints.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Which Claude model to use for all LLM calls.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ────────────────────────────────────────────────────────────
# OpenAI API — Authentication
# ────────────────────────────────────────────────────────────

# Your OpenAI API key (required when AGENT_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here

# ────────────────────────────────────────────────────────────
# OpenAI API — Endpoint & Model
# ────────────────────────────────────────────────────────────

# API base URL — override for proxies, Azure OpenAI, or self-hosted endpoints (e.g. vLLM, Ollama).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Which OpenAI model to use (set via AGENT_MODEL when AGENT_PROVIDER=openai).
# Examples: gpt-4o, gpt-4o-mini, o3, o4-mini
# AGENT_MODEL=gpt-4o

# ────────────────────────────────────────────────────────────
# Provider Reasoning / Thinking Defaults (optional)
# ────────────────────────────────────────────────────────────

# These only apply to the active provider.
# Leave unset to use provider defaults.

# Anthropic Messages thinking config
# Supported types: disabled, adaptive
# Supported display values: summarized, omitted
# Supported effort values: low, medium, high, max
# If type=adaptive and effort is unset on Claude 4.6, this repo defaults effort to medium.
# Anthropic no longer recommends manual budget_tokens for Claude 4.6 integrations.
# ANTHROPIC_THINKING_TYPE=adaptive
# ANTHROPIC_THINKING_DISPLAY=summarized
# ANTHROPIC_REASONING_EFFORT=medium
# ANTHROPIC_THINKING_BUDGET_TOKENS=10000

# OpenAI reasoning effort config
# Applies only to GPT-5.4 models: gpt-5.4, gpt-5.4-*, etc.
# Supported effort values: none, low, medium, high, xhigh
# Any other OpenAI model will reject this setting.
# OPENAI_REASONING_EFFORT=medium

# ────────────────────────────────────────────────────────────
# Planner — Token & Step Limits
# ────────────────────────────────────────────────────────────

# Maximum tool-use reasoning steps per user request before stopping.
AGENT_MAX_STEPS=100

# ────────────────────────────────────────────────────────────
# Timeouts
# ────────────────────────────────────────────────────────────

# Per-tool execution timeout in seconds. Applies to each individual tool call.
# AGENT_TOOL_TIMEOUT=120

# LLM streaming response timeout in seconds. If a streaming call receives no
# data for this long, it is aborted and retried.
# AGENT_STREAM_TIMEOUT=300

# ────────────────────────────────────────────────────────────
# Context Window & Compaction
# ────────────────────────────────────────────────────────────

# Layer 1 — cheap in-turn truncation. When the estimated working token count
# exceeds this, old tool results are truncated before sending the next LLM call.
# AGENT_MAX_WORKING_TOKENS=180000

# Layer 2 — LLM-powered between-turn summarization. When total conversation
# tokens exceed this threshold, older messages are summarized to free space.
# Should be ≤ the model's context window (default matches Anthropic 200K × 75%).
# AGENT_COMPACT_TOKEN_THRESHOLD=150000

# Max chars kept per tool result before truncation (longer results are cut).
# AGENT_MAX_TOOL_RESULT_CHARS=8000

# Max chars kept per tool-use input block before truncation.
# AGENT_MAX_TOOL_USE_INPUT_CHARS=4000

# Observation masking: fully clear tool results older than N messages from the
# end of conversation. Reduces noise without summarization cost.
# AGENT_OBSERVATION_MASK_DISTANCE=5

# After compaction, re-inject the N most recently read/written files so the
# model retains awareness of actively-worked files.
# AGENT_FILE_REINJECTION_COUNT=5

# Cap total tokens re-injected from files after compaction.
# AGENT_FILE_REINJECTION_MAX_TOKENS=50000

# ────────────────────────────────────────────────────────────
# Memory — Conversation Summarization
# ────────────────────────────────────────────────────────────

# Number of messages before triggering automatic conversation summarization.
AGENT_SUMMARIZE_THRESHOLD=20

# Number of recent messages to keep verbatim after summarization.
AGENT_SUMMARIZE_KEEP_RECENT=6

# Max chars of memory content (MEMORY.md + topics) injected into the system prompt.
# AGENT_MAX_MEMORY_PROMPT_CHARS=10000

# ────────────────────────────────────────────────────────────
# Skills — Auto-activation Router
# ────────────────────────────────────────────────────────────

# LLM model used to decide which skills to auto-activate per query.
# Defaults to the active runtime when unset. Override only if you want a dedicated router model.
SKILL_ROUTER_PROVIDER=
SKILL_ROUTER_MODEL=

# Timeout (seconds) for skill router LLM call. If exceeded, falls back to keyword matching.
# Lower = faster response but more fallbacks. Higher = more accurate routing.
SKILL_ROUTER_TIMEOUT=8

# Max chars of skill instructions injected into the system prompt per active skill.
# AGENT_MAX_SKILL_CHARS=8000

# Max chars of skill resource files (references, examples) injected per active skill.
# AGENT_MAX_RESOURCE_CHARS=10000

# ────────────────────────────────────────────────────────────
# Sub-Agent Model Tiers
# ────────────────────────────────────────────────────────────

# Leave unset to inherit the active runtime.
# Supported providers: anthropic, openai
SUBAGENT_FAST_PROVIDER=
SUBAGENT_FAST_MODEL=
SUBAGENT_DEFAULT_PROVIDER=
SUBAGENT_DEFAULT_MODEL=
SUBAGENT_STRONG_PROVIDER=
SUBAGENT_STRONG_MODEL=

# ────────────────────────────────────────────────────────────
# Web Fetch
# ────────────────────────────────────────────────────────────

# Default max chars returned per web_fetch call.
# WEB_FETCH_MAX_LENGTH=8000

# ────────────────────────────────────────────────────────────
# Quality Harness (optional, all off by default)
# ────────────────────────────────────────────────────────────

# JSONL run tracing — records every LLM call, tool call, and event per run()
# into data/traces/<trace_id>.jsonl. Useful for debugging and post-mortems.
# Values: 1, true, yes (anything else = disabled)
# AGENT_TRACE_ENABLED=false

# Pre-completion verification gate — when the model finishes tool use and is
# about to return a final answer, inject a self-check prompt so it can catch
# obvious issues (e.g. untested edits). Only triggers when mutating tools
# (edit_file, write_file, run_shell) were used.
# Values: 1, true, yes (anything else = disabled)
# AGENT_VERIFICATION_ENABLED=false

# ────────────────────────────────────────────────────────────
# TLS / SSL
# ────────────────────────────────────────────────────────────

# Disable TLS certificate verification for LLM API calls.
# Useful when running behind corporate proxies or with self-signed certs.
# Values: 0, false, no → skip verification. Default: 1 (verify).
# SSL_VERIFY=1

# ────────────────────────────────────────────────────────────
# Misc
# ────────────────────────────────────────────────────────────

# Override the working directory the agent considers its "launch dir".
# Defaults to the current working directory when the agent starts.
# LAUNCH_DIR=

# ────────────────────────────────────────────────────────────
# External Services (optional)
# ────────────────────────────────────────────────────────────

# Jina Reader API key — improves web_fetch reliability for protected sites.
# Get one free at https://jina.ai/reader
JINA_API_KEY=your-jina-key-here
