# ============================================================
# AI Agent Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then load into your shell:
#   export $(cat .env | xargs)

# ────────────────────────────────────────────────────────────
# Runtime Selection
# ────────────────────────────────────────────────────────────

# Default provider for interactive chat, subagents, memory summaries, and skill routing.
AGENT_PROVIDER=anthropic

# Default model for the active provider.
AGENT_MODEL=claude-sonnet-4-20250514

# Default max output tokens per response.
AGENT_MAX_TOKENS=16384

# Hard cap for automatic token-budget retries.
AGENT_MAX_TOKENS_CAP=128000

# ────────────────────────────────────────────────────────────
# Anthropic API — Authentication
# ────────────────────────────────────────────────────────────

# Your Anthropic API key (required — unless ANTHROPIC_AUTH_TOKEN is set)
ANTHROPIC_API_KEY=your-key-here

# Alternative auth token — overrides ANTHROPIC_API_KEY when set.
# Useful for API gateways or proxy services with their own credentials.
ANTHROPIC_AUTH_TOKEN=your-auth-token-here

# ────────────────────────────────────────────────────────────
# Anthropic API — Endpoint & Model
# ────────────────────────────────────────────────────────────

# API base URL — override for proxies, gateways, or self-hosted endpoints.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Which Claude model to use for all LLM calls.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ────────────────────────────────────────────────────────────
# OpenAI API — Authentication
# ────────────────────────────────────────────────────────────

OPENAI_API_KEY=your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# ────────────────────────────────────────────────────────────
# Provider Reasoning / Thinking Defaults (optional)
# ────────────────────────────────────────────────────────────

# These only apply to the active provider.
# Leave unset to use provider defaults.

# OpenAI Responses reasoning config
# Supported effort values: none, minimal, low, medium, high, xhigh
# Supported summary values: auto, concise, detailed
# OPENAI_REASONING_EFFORT=high
# OPENAI_REASONING_SUMMARY=concise

# Anthropic Messages thinking config
# Supported types: disabled, adaptive, enabled
# Supported display values: summarized, omitted
# If type=enabled, ANTHROPIC_THINKING_BUDGET_TOKENS must be >= 1024
# and lower than the request max_output_tokens / AGENT_MAX_TOKENS.
# ANTHROPIC_THINKING_TYPE=adaptive
# ANTHROPIC_THINKING_DISPLAY=summarized
# ANTHROPIC_THINKING_BUDGET_TOKENS=2048

# ────────────────────────────────────────────────────────────
# Planner — Token & Step Limits
# ────────────────────────────────────────────────────────────

# Maximum tool-use reasoning steps per user request before stopping.
AGENT_MAX_STEPS=100

# ────────────────────────────────────────────────────────────
# Logging / Observability
# ────────────────────────────────────────────────────────────

# Structured log level for jy-agent internals.
AGENT_LOG_LEVEL=INFO

# JSON-lines log file path. Relative paths resolve from the project root.
AGENT_LOG_FILE=data/logs/jyagent.jsonl

# Log redacted request/response payloads on LLM failures.
AGENT_LOG_LLM_FAILURE_PAYLOADS=1

# Maximum chars to keep for logged text fields before truncation.
AGENT_LOG_MAX_TEXT_CHARS=4000

# ────────────────────────────────────────────────────────────
# Memory — Conversation Summarization
# ────────────────────────────────────────────────────────────

# Number of messages before triggering automatic conversation summarization.
AGENT_SUMMARIZE_THRESHOLD=20

# Number of recent messages to keep verbatim after summarization.
AGENT_SUMMARIZE_KEEP_RECENT=6

# ────────────────────────────────────────────────────────────
# Skills — Auto-activation Router
# ────────────────────────────────────────────────────────────

# LLM model used to decide which skills to auto-activate per query.
# Defaults to the active runtime when unset. Override only if you want a dedicated router model.
SKILL_ROUTER_PROVIDER=
SKILL_ROUTER_MODEL=

# Timeout (seconds) for skill router LLM call. If exceeded, falls back to keyword matching.
# Lower = faster response but more fallbacks. Higher = more accurate routing.
SKILL_ROUTER_TIMEOUT=8

# ────────────────────────────────────────────────────────────
# Sub-Agent Model Tiers
# ────────────────────────────────────────────────────────────

# Leave unset to inherit the active runtime.
SUBAGENT_FAST_PROVIDER=
SUBAGENT_FAST_MODEL=
SUBAGENT_DEFAULT_PROVIDER=
SUBAGENT_DEFAULT_MODEL=
SUBAGENT_STRONG_PROVIDER=
SUBAGENT_STRONG_MODEL=

# ────────────────────────────────────────────────────────────
# External Services (optional)
# ────────────────────────────────────────────────────────────

# Jina Reader API key — improves web_fetch reliability for protected sites.
# Get one free at https://jina.ai/reader
JINA_API_KEY=your-jina-key-here
