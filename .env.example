# ============================================================
# AI Agent Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# run.sh and `python -m jyagent` load .env via python-dotenv.
# Do not use `export $(cat .env | xargs)`; it corrupts quoted JSON values.

# ────────────────────────────────────────────────────────────
# Runtime Selection
# ────────────────────────────────────────────────────────────

# Default provider for interactive chat, subagents, memory summaries, and skill routing.
# Supported providers: anthropic, openai
AGENT_PROVIDER=anthropic

# Default model for the active provider.
AGENT_MODEL=claude-sonnet-4-6

# Default max output tokens per response.
AGENT_MAX_TOKENS=16384

# Hard cap for automatic token-budget retries.
AGENT_MAX_TOKENS_CAP=128000

# ────────────────────────────────────────────────────────────
# Anthropic API — Authentication
# ────────────────────────────────────────────────────────────

# Your Anthropic API key (required — unless ANTHROPIC_AUTH_TOKEN is set)
ANTHROPIC_API_KEY=your-key-here

# Alternative auth token — overrides ANTHROPIC_API_KEY when set.
# Useful for API gateways or proxy services with their own credentials.
ANTHROPIC_AUTH_TOKEN=your-auth-token-here

# ────────────────────────────────────────────────────────────
# Anthropic API — Endpoint & Model
# ────────────────────────────────────────────────────────────

# API base URL — override for proxies, gateways, or self-hosted endpoints.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Extra HTTP headers for Anthropic API calls, as a JSON object.
# Example: send x-origin-agent=stepcode through an API gateway.
# ANTHROPIC_EXTRA_HEADERS='{"x-origin-agent":"stepcode"}'

# Which Claude model to use for all LLM calls.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ────────────────────────────────────────────────────────────
# OpenAI API — Authentication
# ────────────────────────────────────────────────────────────

# Your OpenAI API key (required when AGENT_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here

# ────────────────────────────────────────────────────────────
# OpenAI API — Endpoint & Model
# ────────────────────────────────────────────────────────────

# API base URL — override for proxies, Azure OpenAI, or self-hosted endpoints (e.g. vLLM, Ollama).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Extra HTTP headers for OpenAI API calls, as a JSON object.
# Example: send x-origin-agent=stepcode through an API gateway.
# OPENAI_EXTRA_HEADERS='{"x-origin-agent":"stepcode"}'

# Which OpenAI model to use (set via AGENT_MODEL when AGENT_PROVIDER=openai).
# Examples: gpt-4o, gpt-4o-mini, o3, o4-mini
# AGENT_MODEL=gpt-4o

# ────────────────────────────────────────────────────────────
# Provider Reasoning / Thinking Defaults (optional)
# ────────────────────────────────────────────────────────────

# These only apply to the active provider.
# Leave unset to use provider defaults.

# Anthropic Messages thinking config
# Supported types: disabled, adaptive
# Supported display values: summarized, omitted
# Supported effort values: low, medium, high, max
# If type=adaptive and effort is unset on Claude 4.6, this repo defaults effort to medium.
# Anthropic no longer recommends manual budget_tokens for Claude 4.6 integrations.
# ANTHROPIC_THINKING_TYPE=adaptive
# ANTHROPIC_THINKING_DISPLAY=summarized
# ANTHROPIC_REASONING_EFFORT=medium
# ANTHROPIC_THINKING_BUDGET_TOKENS=10000

# OpenAI reasoning effort config
# Applies only to GPT-5.4 models: gpt-5.4, gpt-5.4-*, etc.
# Supported effort values: none, low, medium, high, xhigh
# Any other OpenAI model will reject this setting.
# OPENAI_REASONING_EFFORT=medium

# ────────────────────────────────────────────────────────────
# Planner — Token & Step Limits
# ────────────────────────────────────────────────────────────

# Maximum tool-use reasoning steps per user request before stopping.
AGENT_MAX_STEPS=100

# ────────────────────────────────────────────────────────────
# Timeouts
# ────────────────────────────────────────────────────────────

# Per-tool execution timeout in seconds. Applies to each individual tool call.
# AGENT_TOOL_TIMEOUT=120

# LLM streaming response timeout in seconds. If a streaming call receives no
# data for this long, it is aborted and retried.
# AGENT_STREAM_TIMEOUT=300

# ────────────────────────────────────────────────────────────
# Context Window & Compaction
# ────────────────────────────────────────────────────────────

# Layer 1 — cheap in-turn truncation. When the estimated working token count
# exceeds this, old tool results are truncated before sending the next LLM call.
# AGENT_MAX_WORKING_TOKENS=180000

# Layer 2 — LLM-powered between-turn summarization. When total conversation
# tokens exceed this threshold, older messages are summarized to free space.
# Should be ≤ the model's context window (default matches Anthropic 200K × 75%).
# AGENT_COMPACT_TOKEN_THRESHOLD=150000

# Max chars kept per tool result before truncation (longer results are cut).
# AGENT_MAX_TOOL_RESULT_CHARS=8000

# Max chars kept per tool-use input block before truncation.
# AGENT_MAX_TOOL_USE_INPUT_CHARS=4000

# Observation masking: fully clear tool results older than N messages from the
# end of conversation. Reduces noise without summarization cost.
# AGENT_OBSERVATION_MASK_DISTANCE=5

# After compaction, re-inject the N most recently read/written files so the
# model retains awareness of actively-worked files.
# AGENT_FILE_REINJECTION_COUNT=5

# Cap total tokens re-injected from files after compaction.
# AGENT_FILE_REINJECTION_MAX_TOKENS=50000

# ────────────────────────────────────────────────────────────
# Memory — Conversation Summarization
# ────────────────────────────────────────────────────────────

# Number of messages before triggering automatic conversation summarization.
AGENT_SUMMARIZE_THRESHOLD=20

# Number of recent messages to keep verbatim after summarization.
AGENT_SUMMARIZE_KEEP_RECENT=6

# Max chars of memory content (MEMORY.md + topics) injected into the system prompt.
# AGENT_MAX_MEMORY_PROMPT_CHARS=10000

# ────────────────────────────────────────────────────────────
# Skills — Activation strategy
# ────────────────────────────────────────────────────────────

# Pre-LLM skill router (opt-in).
#
# When SKILL_PRE_ROUTER=1, an LLM-based router runs before EVERY user turn
# to decide which skills should be active for that turn (diff-based: can
# add AND remove skills). Default OFF because:
#   1. it adds a router LLM call to every turn (latency + cost), and
#   2. an active-set diff would invalidate the Anthropic prompt-cache prefix
#      every time it fires — ~12× cost penalty on cache-heavy workloads.
#
# With the default (OFF), the agent uses progressive disclosure (same pattern
# as Claude Code): the lightweight skill catalog (name + description) is
# always visible to the LLM in the system prompt, and the model self-activates
# skills via the manage_skills tool when it judges them relevant. Active skill
# bodies are then attached as a tail block on the user message — they never
# touch the system prompt — so activation never invalidates the cache.
#
# Turn ON only if you have so many skills that scanning the catalog itself
# becomes expensive (rule of thumb: >50 skills) and you accept the cache cost.
# Truthy: 1, true, yes, on (case-insensitive).
# SKILL_PRE_ROUTER=0

# ──── The settings below ONLY apply when SKILL_PRE_ROUTER=1 ────

# LLM model used by the pre-router to decide which skills to activate.
# Defaults to the active runtime when unset. Override only if you want a
# dedicated, cheaper router model (e.g. Haiku) for cost reasons.
SKILL_ROUTER_PROVIDER=
SKILL_ROUTER_MODEL=

# Timeout (seconds) for skill router LLM call. If exceeded, falls back to
# keyword matching on the catalog.
# Lower = faster response but more fallbacks. Higher = more accurate routing.
SKILL_ROUTER_TIMEOUT=8

# ──── These apply regardless of SKILL_PRE_ROUTER ────

# Max chars of skill instructions injected per active skill (Stage 2 body).
# AGENT_MAX_SKILL_CHARS=8000

# Max chars of skill resource files (references, examples) per active skill.
# AGENT_MAX_RESOURCE_CHARS=10000

# ────────────────────────────────────────────────────────────
# Web Fetch
# ────────────────────────────────────────────────────────────

# Default max chars returned per web_fetch call.
# WEB_FETCH_MAX_LENGTH=8000

# ────────────────────────────────────────────────────────────
# Web Search
# ────────────────────────────────────────────────────────────

# The web_search tool runs a 2-engine cascade — first engine returning
# >= 3 results wins. No API key needed by default.
#
# Default order: SearxNG (if configured) → DuckDuckGo.
# Brave + Mojeek were removed 2026-04: Brave serves a PoW captcha to
# scrapers, and Mojeek IP-blocks all available datacenter / WARP exits.
# Run a SearxNG instance to get richer Brave/Mojeek/Google/Bing aggregation.

# Self-hosted SearxNG instance — when set, jumps to first in the cascade and
# usually wins (it aggregates Google + Bing + Brave + DDG + 70 others into one
# JSON response). Best free quality. No trailing slash.
#   docker run -d --name searxng -p 8888:8080 searxng/searxng
# SEARXNG_URL=http://localhost:8888

# Force a single engine instead of the cascade. Useful for debugging.
# Accepts: searxng | ddg
# WEB_SEARCH_ENGINE=

# ────────────────────────────────────────────────────────────
# Tools — run_shell output bounding
# ────────────────────────────────────────────────────────────

# These knobs tune how run_shell handles command output. Defaults are
# safe for a host-process agent without container isolation; tighten
# for low-RAM hosts, loosen for sandboxed runners.
#
# Memory model: per-stream RAM held = HEAD_BYTES + TAIL_BYTES.
# Outputs above TAIL_BYTES are also tee'd to a file in SPILL_DIR so the
# agent can recover the elided middle via read_file / grep / tail.
# Outputs above HARD_KILL_BYTES on a single stream SIGKILL the child's
# process group as a last-resort circuit breaker.
#
# Malformed values warn to stderr at startup and fall back to the
# default — they are NEVER silently ignored. (This is the explicit
# defense against the Claude Code BASH_MAX_OUTPUT_LENGTH regression
# in v2.1.2+, github.com/anthropics/claude-code/issues/17944, where
# the env var stopped working with no signal to users.)

# In-memory head buffer (banners, command echo, early progress).
# Default: 8192 bytes (8 KB). Min: 0.
# JYAGENT_RUN_SHELL_HEAD_BYTES=8192

# In-memory tail buffer (errors, final result, stack traces).
# Spill-to-disk activates the moment a child writes more than this.
# Default: 131072 bytes (128 KB). Min: 0.
# JYAGENT_RUN_SHELL_TAIL_BYTES=131072

# Per-stream hard-kill threshold. SIGKILLs the child's process group
# when stdout OR stderr crosses this many bytes. Defends the agent
# against runaway children (recursive find, infinite log loops, ...).
# Default: 33554432 bytes (32 MB). Min: 1024.
# JYAGENT_RUN_SHELL_HARD_KILL_BYTES=33554432

# User-visible char cap on the returned ToolResult content. Output
# above this is truncated with a marker. (The head+tail buffer is
# applied first; this cap operates on the decoded final string.)
# Default: 50000. Min: 100.
# JYAGENT_RUN_SHELL_OUTPUT_CHAR_CAP=50000

# Spill-to-disk recovery. When true, large outputs are written to a
# file in SPILL_DIR and the path is included in the result so the
# agent can read_file / grep / tail to recover the elided middle.
# Truthy: 1, true, yes, on (case-insensitive).
# Default: true.
# JYAGENT_RUN_SHELL_SPILL=true

# Where spill files land. Each large run_shell call writes one or two
# files named jyagent_runshell_<out|err>_*.out. The OS reaps /tmp on
# its own schedule; for longer retention point this at a managed dir.
# Default: /tmp.
# JYAGENT_RUN_SHELL_SPILL_DIR=/tmp

# ────────────────────────────────────────────────────────────
# Quality Harness (optional, all off by default)
# ────────────────────────────────────────────────────────────

# JSONL run tracing — records every LLM call, tool call, and event per run()
# into data/traces/<trace_id>.jsonl. Useful for debugging and post-mortems.
# Values: 1, true, yes (anything else = disabled)
# AGENT_TRACE_ENABLED=false

# Pre-completion verification gate — when the model finishes tool use and is
# about to return a final answer, inject a self-check prompt so it can catch
# obvious issues (e.g. untested edits). Only triggers when mutating tools
# (edit_file, write_file, run_shell) were used.
# Values: 1, true, yes (anything else = disabled)
# AGENT_VERIFICATION_ENABLED=false

# ────────────────────────────────────────────────────────────
# TLS / SSL
# ────────────────────────────────────────────────────────────

# Disable TLS certificate verification for LLM API calls.
# Useful when running behind corporate proxies or with self-signed certs.
# Values: 0, false, no → skip verification. Default: 1 (verify).
# SSL_VERIFY=1

# ────────────────────────────────────────────────────────────
# Misc
# ────────────────────────────────────────────────────────────

# Override the working directory the agent considers its "launch dir".
# Defaults to the current working directory when the agent starts.
# LAUNCH_DIR=

# ────────────────────────────────────────────────────────────
# External Services (optional)
# ────────────────────────────────────────────────────────────

# Jina Reader API key — improves web_fetch reliability for protected sites.
# Get one free at https://jina.ai/reader
JINA_API_KEY=your-jina-key-here
